# ── StreamGate .env ────────────────────────────────────────────────────────
# Copy this to .env and fill in the values.
# NEVER commit .env to git.

# Your Arc testnet wallet that RECEIVES payments
STREAMER_WALLET_ADDRESS=0xYourStreamerWalletAddressHere

# Private key for that wallet (needed for EIP-3009 signing in demo mode)
# In production, viewers sign with their OWN key — this is a hackathon simplification
STREAMER_PRIVATE_KEY=0xYourPrivateKeyHere

# Circle developer console → https://console.circle.com
# Create a project, go to API Keys, copy the testnet key
CIRCLE_API_KEY=TEST_API_KEY_HERE

# Circle Gateway base URL (leave as-is for testnet)
CIRCLE_GATEWAY_URL=https://api.circle.com/v1/w3s

# USDC contract address on Arc testnet
# Find at: https://docs.arc.network/arc/references/contract-addresses
GATEWAY_WALLET_CONTRACT=0x_ARC_TESTNET_USDC_CONTRACT_ADDRESS

# Arc testnet chain ID (1516 for Arc testnet)
ARC_TESTNET_CHAIN_ID=1516

# Canteen-hosted Arc testnet RPC (from ARC CLI docs)
ARC_RPC_URL=https://rpc.arc-testnet.canteen.dev

# ── Stream settings ────────────────────────────────────────────────────────
# How much viewers pay per second (in USDC)
BASE_RATE_PER_SEC=0.001

# Sessions shorter than this are free (catches page refreshes)
MIN_BILLABLE_SECS=5

# When concurrent viewers exceeds this, surge pricing kicks in
SURGE_VIEWER_THRESHOLD=10

# Surge multiplier (1.5 = 50% higher rate during peak)
SURGE_MULTIPLIER=1.5

# ── Owncast security ───────────────────────────────────────────────────────
# Set in Owncast admin → Integrations → Webhooks → Secret
# Leave empty to skip signature verification (dev mode)
OWNCAST_WEBHOOK_SECRET=

# ── App ────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
DB_PATH=streamgate.db
